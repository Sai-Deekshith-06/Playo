# ===== MAIL/EMAIL CONFIGURATION (Required for Password Reset Feature) =====
# SMTP Server Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@playo.com

# ===== FRONTEND CONFIGURATION =====
# Frontend base URL for password reset links in emails
APP_FRONTEND_URL=http://localhost:5173

# ===== EXISTING CONFIGURATION =====
# Server Configuration
SERVER_PORT=8040

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_HOSTNAME=auth-server

# Database Configuration
DB_HOST=localhost:5432
DB_NAME=playo_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=admin

# Cloudinary Configuration
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API=your-cloudinary-api-key
CLOUDINARY_SECRET=your-cloudinary-secret

# Admin Account Seeding
APP_ADMIN_EMAIL=admin@playo.com
APP_ADMIN_PASSWORD=admin123
APP_ADMIN_NAME=Playo Admin
APP_ADMIN_PHONE=9999999999

# ===== GMAIL APP PASSWORD SETUP =====
# To use Gmail for sending emails:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password and paste it above as MAIL_PASSWORD
# 4. Use complete Gmail address as MAIL_USERNAME (e.g., your-email@gmail.com)
#
# Alternative SMTP providers:
# - Sendgrid: MAIL_HOST=smtp.sendgrid.net, MAIL_PASSWORD=SG.<api-key>
# - AWS SES: MAIL_HOST=email-smtp.<region>.amazonaws.com
# - Mailgun: MAIL_HOST=smtp.mailgun.org
